{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hall Booking System",
  "version": "1.0.0",
  "identifier": "com.hallbooking.desktop",
  "build": {
    "frontendDist": "../frontend/build",
    "devUrl": "http://127.0.0.1:4503",
    "beforeBuildCommand": "npm run desktop:prepare:tauri"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "../backend",
      "../frontend/build"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
